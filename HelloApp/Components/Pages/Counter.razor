@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="() => Amount++">Increase Increment</button>
<button class="btn btn-primary" @onclick="() => Amount--">Decrease Increment</button>
<br />
<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>
<button class="btn btn-primary" @onclick="DecrementCount">Click me</button>

@code {
    private int currentCount = 0;

    public int Amount { get; set; } = 1;

    private void IncrementCount()
    {
        currentCount += Amount;
    }
    private void DecrementCount()
    {
        if ((currentCount -= Amount) <= 0) Amount = 0;
    }
}
